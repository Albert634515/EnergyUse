<UserControl x:Class="WpfUI.Views.Controls.ChartCompareLiveChartsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Labels -->
            <RowDefinition Height="Auto"/>
            <!-- Form -->
            <RowDefinition Height="Auto"/>
            <!-- Options + Buttons -->
            <RowDefinition Height="*"/>
            <!-- Chart -->
        </Grid.RowDefinitions>

        <!-- LABELS -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 12">

            <Border DataContext="{Binding ConsumptionLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4" Margin="0 0 12 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding ProductionLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4" Margin="0 0 12 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding NettoLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

        </StackPanel>

        <!-- FORM -->
        <Grid Grid.Row="1" Margin="0 0 0 12"
              ColumnDefinitions="Auto,150,20,Auto,150,20,Auto,150,20,Auto,150">

            <TextBlock Grid.Column="0" Text="Period type" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding PeriodTypes}"
                      SelectedItem="{Binding SelectedPeriodType}"
                      DisplayMemberPath="Description"/>

            <TextBlock Grid.Column="3" Text="Start year" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="4"
                      ItemsSource="{Binding Years}"
                      SelectedItem="{Binding StartYear}"/>

            <TextBlock Grid.Column="6" Text="End year" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="7"
                      ItemsSource="{Binding Years}"
                      SelectedItem="{Binding EndYear}"/>

            <TextBlock Grid.Column="9"
                       Text="{Binding NumberLabel}"
                       FontWeight="SemiBold"
                       Visibility="{Binding IsNumberVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <ComboBox Grid.Column="10"
                      ItemsSource="{Binding NumberList}"
                      SelectedItem="{Binding SelectedNumber}"
                      Visibility="{Binding IsNumberVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>

        <!-- OPTIONS + BUTTONS -->
        <Grid Grid.Row="2" Margin="0 0 0 12"
              ColumnDefinitions="Auto,200,40,Auto,200,40,Auto,200,*">

            <!-- SHOW BY -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Show by" FontWeight="SemiBold"/>
                <RadioButton Content="Category" IsChecked="{Binding ShowByCategory}"/>
                <RadioButton Content="Subcategory" IsChecked="{Binding ShowBySubCategory}"/>
                <RadioButton Content="Total" IsChecked="{Binding ShowByTotal}"/>
            </StackPanel>

            <!-- TYPE -->
            <StackPanel Grid.Column="3">
                <TextBlock Text="Type" FontWeight="SemiBold"/>
                <RadioButton Content="Rate" IsChecked="{Binding ShowTypeRate}"/>
                <RadioButton Content="Value" IsChecked="{Binding ShowTypeValue}"/>
                <RadioButton Content="Efficiency"
                             IsChecked="{Binding ShowTypeEfficiency}"
                             Visibility="{Binding IsEfficiencyVisible,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <!-- OPTIONS -->
            <StackPanel Grid.Column="6">
                <TextBlock Text="Options" FontWeight="SemiBold"/>
                <CheckBox Content="Predict missing data" IsChecked="{Binding PredictMissingData}"/>
                <CheckBox Content="Show stacked" IsChecked="{Binding ShowStacked}"/>
            </StackPanel>

            <!-- BUTTONS -->
            <StackPanel Grid.Column="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="Reset"
                        Width="140"
                        Command="{Binding ResetCommand}"
                        Margin="0 0 0 5"/>

                <Button Content="Export"
                        Width="140"
                        Command="{Binding ExportCommand}"/>
            </StackPanel>

        </Grid>

        <!-- CHART -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"/>
        </Border>

    </Grid>
</UserControl>