<UserControl x:Class="WpfUI.Views.Controls.ChartCompareLiveChartsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>

        <!-- Label visibility -->
        <Style x:Key="LabelBorderVisibilityStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Visible}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Efficiency radio visibility -->
        <Style x:Key="EfficiencyRadioVisibilityStyle" TargetType="RadioButton">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEfficiencyVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Day dropdown visibility -->
        <Style x:Key="DayPanelVisibilityStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDayVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Form label -->
        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Labels -->
            <RowDefinition Height="Auto"/>
            <!-- Form -->
            <RowDefinition Height="Auto"/>
            <!-- Options -->
            <RowDefinition Height="*"/>
            <!-- Chart -->
        </Grid.RowDefinitions>

        <!-- LABELS -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 15">
            <Border DataContext="{Binding ConsumptionLabel}"
                    Style="{StaticResource LabelBorderVisibilityStyle}"
                    Background="{Binding BackColor}"
                    Padding="6 3"
                    Margin="0 0 10 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding ProductionLabel}"
                    Style="{StaticResource LabelBorderVisibilityStyle}"
                    Background="{Binding BackColor}"
                    Padding="6 3"
                    Margin="0 0 10 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding NettoLabel}"
                    Style="{StaticResource LabelBorderVisibilityStyle}"
                    Background="{Binding BackColor}"
                    Padding="6 3">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>
        </StackPanel>

        <!-- FORM -->
        <Grid Grid.Row="1" Margin="0 0 0 15"
              ColumnDefinitions="Auto,150,20,Auto,100,20,Auto,100,20,Auto,100,20,Auto,100">

            <!-- Period type -->
            <TextBlock Grid.Column="0" Text="Period type" Style="{StaticResource FormLabel}"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding PeriodTypes}"
                      SelectedItem="{Binding SelectedPeriodType}"
                      DisplayMemberPath="Description"/>

            <!-- Start year -->
            <TextBlock Grid.Column="3" Text="Start year" Style="{StaticResource FormLabel}"/>
            <ComboBox Grid.Column="4"
                      ItemsSource="{Binding Years}"
                      SelectedItem="{Binding StartYear}"/>

            <!-- End year -->
            <TextBlock Grid.Column="6" Text="End year" Style="{StaticResource FormLabel}"/>
            <ComboBox Grid.Column="7"
                      ItemsSource="{Binding Years}"
                      SelectedItem="{Binding EndYear}"/>

            <!-- Number 1 -->
            <TextBlock Grid.Column="9" Text="{Binding NumberLabel}" Style="{StaticResource FormLabel}"/>
            <ComboBox Grid.Column="10"
                      ItemsSource="{Binding NumberList}"
                      SelectedItem="{Binding SelectedNumber}"/>

            <!-- Number 2 (Day) -->
            <StackPanel Grid.Column="12"
                        Style="{StaticResource DayPanelVisibilityStyle}">
                <TextBlock Text="Day" Style="{StaticResource FormLabel}"/>
                <ComboBox ItemsSource="{Binding DayList}"
                          SelectedItem="{Binding SelectedDay}"/>
            </StackPanel>

        </Grid>

        <!-- OPTIONS -->
        <Grid Grid.Row="2" Margin="0 0 0 15"
              ColumnDefinitions="Auto,150,40,Auto,150,40,Auto,150,*">

            <!-- Show by -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Show by" Style="{StaticResource FormLabel}"/>
                <RadioButton Content="Category" IsChecked="{Binding ShowByCategory}"/>
                <RadioButton Content="Subcategory" IsChecked="{Binding ShowBySubCategory}"/>
                <RadioButton Content="Total" IsChecked="{Binding ShowByTotal}"/>
            </StackPanel>

            <!-- Type -->
            <StackPanel Grid.Column="3">
                <TextBlock Text="Type" Style="{StaticResource FormLabel}"/>
                <RadioButton Content="Rate" IsChecked="{Binding ShowTypeRate}"/>
                <RadioButton Content="Value" IsChecked="{Binding ShowTypeValue}"/>
                <RadioButton Content="Efficiency"
                             IsChecked="{Binding ShowTypeEfficiency}"
                             Style="{StaticResource EfficiencyRadioVisibilityStyle}"/>
            </StackPanel>

            <!-- Options -->
            <StackPanel Grid.Column="6">
                <TextBlock Text="Options" Style="{StaticResource FormLabel}"/>
                <CheckBox Content="Predict missing data" IsChecked="{Binding PredictMissingData}"/>
                <CheckBox Content="Show stacked" IsChecked="{Binding ShowStacked}"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Column="8" HorizontalAlignment="Right">
                <Button Content="Reset"
                        Command="{Binding ResetCommand}"
                        Width="100"
                        Margin="0 0 0 5"/>
                <Button Content="Export"
                        Command="{Binding ExportCommand}"
                        Width="100"/>
            </StackPanel>

        </Grid>

        <!-- CHART -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"/>
        </Border>

    </Grid>
</UserControl>