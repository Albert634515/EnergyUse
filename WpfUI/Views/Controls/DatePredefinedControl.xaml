<UserControl x:Class="WpfUI.Views.Controls.DatePredefinedControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Margin="10">

        <!-- TOOLBAR -->
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddCommand}">
                <Image Source="/Resources/add_24x24.png" Width="20"/>
            </Button>
            <Button Command="{Binding SaveCommand}">
                <Image Source="/Resources/tick-mark_24x24.png" Width="20"/>
            </Button>
            <Button Command="{Binding CancelCommand}">
                <Image Source="/Resources/clear_24x24.png" Width="20"/>
            </Button>
            <Button Command="{Binding DeleteCommand}">
                <Image Source="/Resources/delete_24x24.png" Width="20"/>
            </Button>
            <Button Command="{Binding RefreshCommand}">
                <Image Source="/Resources/clock_24x24.png" Width="20"/>
            </Button>
        </ToolBar>

        <!-- GRID + EDITVELDEN -->
        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: DATAGRID -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Dates}"
                      SelectedItem="{Binding SelectedDate}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Margin="0,0,10,0">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Start"
                                        Binding="{Binding StartDate}"
                                        Width="120"/>

                    <DataGridTextColumn Header="End"
                                        Binding="{Binding EndDate}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Energy Type"
                                        Binding="{Binding EnergyTypeName}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Tariff Group"
                                        Binding="{Binding TarifGroupName}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- RIGHT: EDIT FIELDS -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Start Date -->
                <TextBlock Text="Start Date:"
                           Grid.Row="0" Grid.Column="0"
                           Margin="0,0,10,5"
                           VerticalAlignment="Center"/>

                <DatePicker SelectedDate="{Binding SelectedDate.StartDate, Mode=TwoWay}"
                            Grid.Row="0" Grid.Column="1"
                            Margin="0,0,0,5"/>

                <!-- End Date -->
                <TextBlock Text="End Date:"
                           Grid.Row="1" Grid.Column="0"
                           Margin="0,0,10,5"
                           VerticalAlignment="Center"/>

                <DatePicker SelectedDate="{Binding SelectedDate.EndDate, Mode=TwoWay}"
                            Grid.Row="1" Grid.Column="1"
                            Margin="0,0,0,5"/>

                <!-- Energy Type -->
                <TextBlock Text="Energy Type:"
                           Grid.Row="2" Grid.Column="0"
                           Margin="0,0,10,5"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Row="2" Grid.Column="1"
                          ItemsSource="{Binding DataContext.EnergyTypes,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedValue="{Binding SelectedDate.EnergyTypeId, Mode=TwoWay}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,5"/>

                <!-- Tariff Group -->
                <TextBlock Text="Tariff Group:"
                           Grid.Row="3" Grid.Column="0"
                           Margin="0,0,10,5"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Row="3" Grid.Column="1"
                          ItemsSource="{Binding DataContext.TariffGroups,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedValue="{Binding SelectedDate.TariffGroupId, Mode=TwoWay}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Description"
                          Margin="0,0,0,5"/>

            </Grid>

        </Grid>

    </DockPanel>

</UserControl>