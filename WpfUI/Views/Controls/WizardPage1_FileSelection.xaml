<UserControl x:Class="WpfUI.Views.Controls.WizardPage1_FileSelection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titel -->
            <RowDefinition Height="Auto"/>
            <!-- Nieuw / Bestaand -->
            <RowDefinition Height="Auto"/>
            <!-- Directory -->
            <RowDefinition Height="Auto"/>
            <!-- Bestandsnaam -->
            <RowDefinition Height="*"/>
            <!-- Opties -->
        </Grid.RowDefinitions>

        <!-- Titel -->
        <TextBlock Text="Kies een nieuw of bestaand databasebestand"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,25"/>

        <!-- Nieuw / Bestaand -->
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <RadioButton Content="Nieuw bestand"
                         FontSize="16"
                         IsChecked="{Binding IsNewFile}" />
            <RadioButton Content="Bestaand bestand"
                         FontSize="16"
                         Margin="0,8,0,0"
                         IsChecked="{Binding IsExistingFile}" />
        </StackPanel>

        <!-- DIRECTORY (bovenaan) -->
        <StackPanel Grid.Row="2" Margin="0,25,0,0">

            <TextBlock Text="Doelmap"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding TargetDirectory}"
                         FontSize="16"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>

                <Button Grid.Column="1"
                        Command="{Binding SelectDirectoryCommand}"
                        Width="140" Height="32">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/Resources/open-file-folder-icon.png"
                               Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Selecteer"/>
                    </StackPanel>
                </Button>
            </Grid>

        </StackPanel>

        <!-- BESTANDSNAAM (onder directory) -->
        <StackPanel Grid.Row="3" Margin="0,25,0,0">

            <TextBlock Text="Databasebestand"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding NewFilePath}"
                         FontSize="16"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>

                <Button Grid.Column="1"
                        Command="{Binding SelectFileCommand}"
                        Width="140" Height="32">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/Resources/open-file-icon.png"
                               Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Selecteer"/>
                    </StackPanel>
                </Button>
            </Grid>

        </StackPanel>

        <!-- Opties -->
        <StackPanel Grid.Row="4" Margin="0,35,0,0">
            <CheckBox Content="Voeg basisgegevens toe"
                      FontSize="16"
                      IsChecked="{Binding AddBaseData}" />
            <CheckBox Content="Instellen als standaardbestand"
                      FontSize="16"
                      Margin="0,12,0,0"
                      IsChecked="{Binding SetAsDefaultFileOption}" />
        </StackPanel>

    </Grid>
</UserControl>