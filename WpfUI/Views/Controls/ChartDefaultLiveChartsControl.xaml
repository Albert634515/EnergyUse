<UserControl x:Class="WpfUI.Views.Controls.ChartDefaultLiveChartsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Periode -->
            <RowDefinition Height="Auto"/>
            <!-- Type + ShowBy + Options + Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Labels -->
            <RowDefinition Height="*"/>
            <!-- Chart -->
        </Grid.RowDefinitions>

        <!-- PERIODE -->
        <Grid Grid.Row="0" Margin="0 0 0 12"
              ColumnDefinitions="Auto,150,20,Auto,150,20,Auto,150,20,Auto,150">

            <TextBlock Grid.Column="0" Text="Periode" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding PeriodTypes}"
                      SelectedItem="{Binding SelectedPeriodType}"
                      DisplayMemberPath="Description"/>

            <TextBlock Grid.Column="3" Text="Van" FontWeight="SemiBold"/>
            <DatePicker Grid.Column="4" SelectedDate="{Binding FromDate}"/>

            <TextBlock Grid.Column="6" Text="Tot" FontWeight="SemiBold"/>
            <DatePicker Grid.Column="7" SelectedDate="{Binding TillDate}"/>

            <TextBlock Grid.Column="9" Text="Vergelijk met" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="10"
                      ItemsSource="{Binding EnergyTypes}"
                      SelectedItem="{Binding SelectedCompareEnergyType}"
                      DisplayMemberPath="Name"/>
        </Grid>

        <!-- TYPE + SHOWBY + OPTIONS + BUTTONS -->
        <Grid Grid.Row="1" Margin="0 0 0 12"
              ColumnDefinitions="Auto,200,40,Auto,200,40,Auto,200,*">

            <!-- TYPE -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Type" FontWeight="SemiBold"/>
                <RadioButton Content="Rate" IsChecked="{Binding ShowTypeRate}"/>
                <RadioButton Content="Value" IsChecked="{Binding ShowTypeValue}"/>
                <RadioButton Content="Efficiency"
                             IsChecked="{Binding ShowTypeEfficiency}"
                             Visibility="{Binding IsEfficiencyVisible,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <!-- SHOW BY -->
            <StackPanel Grid.Column="3">
                <TextBlock Text="Weergave" FontWeight="SemiBold"/>
                <RadioButton Content="Categorie" IsChecked="{Binding ShowByCategory}"/>
                <RadioButton Content="Subcategorie" IsChecked="{Binding ShowBySubCategory}"/>
                <RadioButton Content="Totaal" IsChecked="{Binding ShowByTotal}"/>
            </StackPanel>

            <!-- OPTIONS -->
            <StackPanel Grid.Column="6">
                <TextBlock Text="Options" FontWeight="SemiBold"/>
                <CheckBox Content="Stacked" IsChecked="{Binding ShowStacked}"/>
                <CheckBox Content="Gemiddelde lijn" IsChecked="{Binding ShowAverage}"/>
                <CheckBox Content="Voorspel ontbrekende data" IsChecked="{Binding PredictMissingData}"/>
            </StackPanel>

            <!-- BUTTONS -->
            <StackPanel Grid.Column="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="Reset"
                        Width="140"
                        Command="{Binding ResetCommand}"
                        Margin="0 0 0 5"/>

                <Button Content="Export"
                        Width="140"
                        Command="{Binding ExportCommand}"/>
            </StackPanel>

        </Grid>

        <!-- LABELS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 0 0 12">

            <Border DataContext="{Binding ConsumptionLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4" Margin="0 0 12 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding ProductionLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4" Margin="0 0 12 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding NettoLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

        </StackPanel>

        <!-- CHART -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"/>
        </Border>

    </Grid>
</UserControl>