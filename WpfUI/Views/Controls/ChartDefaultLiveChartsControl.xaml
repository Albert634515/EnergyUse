<UserControl x:Class="WpfUI.Views.Controls.ChartDefaultLiveChartsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>

        <Style TargetType="StackPanel">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="4"/>
        </Style>

        <!-- Visibility zonder converter -->
        <Style x:Key="EfficiencyVisibilityStyle" TargetType="RadioButton">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEfficiencyVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Periode + Compare -->
            <RowDefinition Height="Auto"/>
            <!-- Type + ShowBy -->
            <RowDefinition Height="Auto"/>
            <!-- Checkboxes -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Labels -->
            <RowDefinition Height="*"/>
            <!-- Chart -->
        </Grid.RowDefinitions>

        <!-- PERIODE -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">

            <StackPanel>
                <Label Content="Periode"/>
                <ComboBox Width="150"
          ItemsSource="{Binding PeriodTypes}"
          SelectedItem="{Binding SelectedPeriodType}"
          DisplayMemberPath="Description"
          SelectedValuePath="Key"/>

            </StackPanel>

            <StackPanel>
                <Label Content="Van"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="140"/>
            </StackPanel>

            <StackPanel>
                <Label Content="Tot"/>
                <DatePicker SelectedDate="{Binding TillDate}" Width="140"/>
            </StackPanel>

            <StackPanel>
                <Label Content="Vergelijk met"/>
                <ComboBox Width="150"
                          ItemsSource="{Binding EnergyTypes}"
                          SelectedItem="{Binding SelectedCompareEnergyType}"/>
            </StackPanel>

        </StackPanel>

        <!-- TYPE + SHOWBY -->
        <StackPanel Grid.Row="1" Orientation="Horizontal">

            <StackPanel>
                <Label Content="Type"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Rate" IsChecked="{Binding ShowTypeRate}"/>
                    <RadioButton Content="Value" IsChecked="{Binding ShowTypeValue}"/>
                    <RadioButton Content="Efficiency"
                                 IsChecked="{Binding ShowTypeEfficiency}"
                                 Style="{StaticResource EfficiencyVisibilityStyle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel>
                <Label Content="Weergave"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Categorie" IsChecked="{Binding ShowByCategory}"/>
                    <RadioButton Content="Subcategorie" IsChecked="{Binding ShowBySubCategory}"/>
                    <RadioButton Content="Totaal" IsChecked="{Binding ShowByTotal}"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>

        <!-- CHECKBOXES -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <CheckBox Content="Stacked" IsChecked="{Binding ShowStacked}"/>
            <CheckBox Content="Gemiddelde lijn" IsChecked="{Binding ShowAverage}"/>
            <CheckBox Content="Voorspel ontbrekende data" IsChecked="{Binding PredictMissingData}"/>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Reset" Width="120" Command="{Binding ResetCommand}"/>
            <Button Content="Exporteren naar Excel" Width="180" Command="{Binding ExportCommand}"/>
        </StackPanel>

        <!-- LABELS -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Label Content="{Binding ConsumptionLabel.Text}"
                   Background="{Binding ConsumptionLabel.BackColor}"
                   Foreground="{Binding ConsumptionLabel.ForeColor}"
                   Visibility="{Binding ConsumptionLabel.Visible}"/>

            <Label Content="{Binding ProductionLabel.Text}"
                   Background="{Binding ProductionLabel.BackColor}"
                   Foreground="{Binding ProductionLabel.ForeColor}"
                   Visibility="{Binding ProductionLabel.Visible}"/>

            <Label Content="{Binding NettoLabel.Text}"
                   Background="{Binding NettoLabel.BackColor}"
                   Foreground="{Binding NettoLabel.ForeColor}"
                   Visibility="{Binding NettoLabel.Visible}"/>
        </StackPanel>

        <!-- CHART -->
        <Border Grid.Row="5" BorderBrush="LightGray" BorderThickness="1" Padding="10">
            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"/>
        </Border>

    </Grid>
</UserControl>