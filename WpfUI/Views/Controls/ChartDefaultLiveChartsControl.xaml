<UserControl x:Class="WpfUI.Views.Controls.ChartDefaultLiveChartsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Periode -->
            <RowDefinition Height="Auto"/>
            <!-- Type + ShowBy + Options + Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Labels -->
            <RowDefinition Height="*"/>
            <!-- Chart -->
        </Grid.RowDefinitions>

        <!-- Filters en opties, gegroepeerd zoals in de WinForms-versie. -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="215"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="95"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Periode:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox Width="145" ItemsSource="{Binding PeriodTypes}" SelectedItem="{Binding SelectedPeriodType}" DisplayMemberPath="Description"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Vergelijk met:" Width="90" VerticalAlignment="Center"/>
                    <ComboBox Width="115" ItemsSource="{Binding EnergyTypes}" SelectedItem="{Binding SelectedCompareEnergyType}" DisplayMemberPath="Name"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Van:" Width="45" VerticalAlignment="Center"/>
                    <DatePicker Width="130" SelectedDate="{Binding FromDate}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tot:" Width="45" VerticalAlignment="Center"/>
                    <DatePicker Width="130" SelectedDate="{Binding TillDate}"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type:" VerticalAlignment="Center"/>
                <RadioButton Grid.Row="0" Grid.Column="1" Content="Rate" GroupName="ShowType" IsChecked="{Binding ShowTypeRate}" Margin="0,0,0,6"/>
                <RadioButton Grid.Row="0" Grid.Column="2" Content="Value" GroupName="ShowType" IsChecked="{Binding ShowTypeValue}" Margin="0,0,0,6"/>
                <RadioButton Grid.Row="0" Grid.Column="3" Content="Efficiency" IsChecked="{Binding ShowTypeEfficiency}"
                             GroupName="ShowType" Margin="0,0,0,6" Visibility="{Binding IsEfficiencyVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Weergave:" VerticalAlignment="Center"/>
                <RadioButton Grid.Row="1" Grid.Column="1" Content="Categorie" GroupName="ShowBy" IsChecked="{Binding ShowByCategory}"/>
                <RadioButton Grid.Row="1" Grid.Column="2" Content="Subcategorie" GroupName="ShowBy" IsChecked="{Binding ShowBySubCategory}"/>
                <RadioButton Grid.Row="1" Grid.Column="3" Content="Totaal" GroupName="ShowBy" IsChecked="{Binding ShowByTotal}"/>
            </Grid>

            <StackPanel Grid.Column="3">
                <CheckBox Content="Voorspel ontbrekende data" IsChecked="{Binding PredictMissingData}" Margin="0,0,0,5"/>
                <CheckBox Content="Stacked" IsChecked="{Binding ShowStacked}" Margin="0,0,0,5"/>
                <CheckBox Content="Gemiddelde lijn" IsChecked="{Binding ShowAverage}"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <Button Content="Reset" Width="90" Command="{Binding ResetCommand}" Margin="0,0,0,6"/>
                <Button Content="Export" Width="90" Command="{Binding ExportCommand}"/>
            </StackPanel>
        </Grid>

        <!-- LABELS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 0 0 12">

            <Border DataContext="{Binding ConsumptionLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4" Margin="0 0 12 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding ProductionLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4" Margin="0 0 12 0">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

            <Border DataContext="{Binding NettoLabel}"
                    Background="{Binding BackColor}"
                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="6" CornerRadius="4">
                <TextBlock Text="{Binding Text}" Foreground="{Binding ForeColor}"/>
            </Border>

        </StackPanel>

        <!-- CHART -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"/>
        </Border>

    </Grid>
</UserControl>
