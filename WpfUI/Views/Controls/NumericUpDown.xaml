<UserControl x:Class="WpfUI.Views.Controls.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="32" Width="90">

    <Border BorderBrush="#AAA" BorderThickness="1" CornerRadius="4" Padding="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="4,0"/>

            <StackPanel Grid.Column="1" Orientation="Vertical">
                <Button Content="▲"
                        FontSize="10"
                        Height="13"
                        Command="{Binding IncreaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="22"/>

                <Button Content="▼"
                        FontSize="10"
                        Height="13"
                        Command="{Binding DecreaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="23"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>