<Window x:Class="WpfUI.Views.Windows.SetupNewFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setup New File"
        Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FAFAFA">

    <Grid>

        <!-- LAYOUT: 3 rijen -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Stap-indicator -->
            <RowDefinition Height="*"/>
            <!-- Wizard content -->
            <RowDefinition Height="Auto"/>
            <!-- Navigatie -->
        </Grid.RowDefinitions>

        <!-- ⭐ STAP-INDICATOR ⭐ -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,20"
                    Background="Transparent">

            <!-- Stap 1 -->
            <Border Padding="10"
                    Margin="10,0"
                    CornerRadius="6"
                    Background="{Binding Step1Background}">
                <TextBlock Text="1. Bestand"
                           FontWeight="Bold"
                           Foreground="{Binding Step1Foreground}"/>
            </Border>

            <!-- Stap 2 (Adres) — dynamisch zichtbaar -->
            <Border Padding="10"
                    Margin="10,0"
                    CornerRadius="6"
                    Background="{Binding Step2Background}"
                    Visibility="{Binding Step2Visible}">
                <TextBlock Text="2. Adres"
                           FontWeight="Bold"
                           Foreground="{Binding Step2Foreground}"/>
            </Border>

            <!-- Stap 3 (Energietypes) — dynamisch zichtbaar -->
            <Border Padding="10"
                    Margin="10,0"
                    CornerRadius="6"
                    Background="{Binding Step3Background}"
                    Visibility="{Binding Step3Visible}">
                <TextBlock Text="3. Energietypes"
                           FontWeight="Bold"
                           Foreground="{Binding Step3Foreground}"/>
            </Border>

            <!-- Stap 4 -->
            <Border Padding="10"
                    Margin="10,0"
                    CornerRadius="6"
                    Background="{Binding Step4Background}">
                <TextBlock Text="4. Overzicht"
                           FontWeight="Bold"
                           Foreground="{Binding Step4Foreground}"/>
            </Border>

        </StackPanel>

        <!-- ⭐ WIZARD CONTENT ⭐ -->
        <Border Grid.Row="1"
                Margin="20"
                Padding="20"
                Background="White"
                CornerRadius="8"
                BorderBrush="#DDDDDD"
                BorderThickness="1">
            <ContentControl Content="{Binding CurrentPage}"/>
        </Border>

        <!-- ⭐ NAVIGATIE ⭐ -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                Padding="15"
                BorderThickness="1,1,0,0"
                BorderBrush="#DDDDDD">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <!-- Vorige -->
                <Button Content="Vorige"
                        Width="120"
                        Margin="0,0,10,0"
                        Command="{Binding PreviousCommand}"
                        Visibility="{Binding PreviousVisible}"/>

                <!-- Volgende -->
                <Button Content="Volgende"
                        Width="120"
                        Margin="0,0,10,0"
                        Command="{Binding NextCommand}"
                        Visibility="{Binding NextVisible}"/>

                <!-- Setup file -->
                <Button Content="Setup file"
                        Width="120"
                        Command="{Binding CreateDbCommand}"
                        Visibility="{Binding FinishVisible}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>