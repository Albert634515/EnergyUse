<Window x:Class="WpfUI.Views.Windows.RatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WpfUI.Views.Controls"
        Title="Energy Rates"
        Height="800" Width="1100"
        ShowInTaskbar="False">

    <DockPanel>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddRateCommand}" Content="Add"/>
            <Button Command="{Binding SaveRateCommand}" Content="Save"/>
            <Button Command="{Binding CancelRateCommand}" Content="Cancel"/>
            <Button Command="{Binding DeleteRateCommand}" Content="Delete"/>
            <Button Command="{Binding RefreshRatesCommand}" Content="Refresh"/>
            <Button Command="{Binding CloseCommand}" Content="Close"/>
        </ToolBar>

        <!-- Statusbar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding RateTaxInfoText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main Layout -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Filters -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- FILTERS -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Energy Type"/>
                    <ComboBox ItemsSource="{Binding EnergyTypes}"
                              SelectedItem="{Binding SelectedEnergyType}"
                              DisplayMemberPath="Name"
                              Width="180"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Cost Category"/>
                    <ComboBox ItemsSource="{Binding CostCategories}"
                              SelectedItem="{Binding SelectedCostCategory}"
                              DisplayMemberPath="Name"
                              Width="180"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Tariff Group"/>
                    <ComboBox ItemsSource="{Binding TariffGroups}"
                              SelectedItem="{Binding SelectedTariffGroup}"
                              DisplayMemberPath="Description"
                              Width="180"/>
                </StackPanel>

                <TextBlock Text="{Binding AlwaysCalculatedWithText}"
                           VerticalAlignment="Bottom"
                           Margin="20,0,0,0"
                           FontStyle="Italic">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAlwaysCalculatedWithVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>

            <!-- CONTENT: LEFT = Rates + Staffel, RIGHT = Details -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Left -->
                    <ColumnDefinition Width="420"/>
                    <!-- Right -->
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <!-- Rates -->
                        <RowDefinition Height="*"/>
                        <!-- Staffel -->
                    </Grid.RowDefinitions>

                    <!-- RATES GRID -->
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Rates}"
                              SelectedItem="{Binding SelectedRate}"
                              AutoGenerateColumns="False"
                              Margin="0,0,0,10">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Start"
                                                Binding="{Binding StartRate, StringFormat=\{0:dd-MM-yyyy\}}"/>
                            <DataGridTextColumn Header="End"
                                                Binding="{Binding EndRate, StringFormat=\{0:dd-MM-yyyy\}}"/>
                            <DataGridTextColumn Header="Rate"
                                                Binding="{Binding RateValue, StringFormat=N5}" />
                            <DataGridTextColumn Header="Expected Change"
                                                Binding="{Binding ExpectedPriceChange, StringFormat=N3}" />
                            <DataGridTextColumn Header="Price Change"
                                                Binding="{Binding PriceChange, StringFormat=N3}" />
                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding Description}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- STAFFEL GRID -->
                    <GroupBox Grid.Row="1" Header="Staffel">
                        <controls:StaffelControl DataContext="{Binding StaffelVM}">
                            <controls:StaffelControl.Style>
                                <Style TargetType="controls:StaffelControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsStaffel,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:StaffelControl.Style>
                        </controls:StaffelControl>
                    </GroupBox>
                </Grid>

                <!-- RIGHT SIDE: RATE DETAILS -->
                <GroupBox Grid.Column="1" Header="Rate Details">
                    <Grid Margin="10">

                        <Grid.Resources>

                            <!-- Labels -->
                            <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>

                            <!-- TextBox -->
                            <Style x:Key="DetailTextBoxStyle" TargetType="TextBox">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="Height" Value="26"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>

                            <!-- ComboBox -->
                            <Style x:Key="DetailComboBoxStyle" TargetType="ComboBox">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="Height" Value="26"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>

                            <!-- DatePicker -->
                            <Style x:Key="DetailDatePickerStyle" TargetType="DatePicker">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="Height" Value="26"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>

                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Rate Type -->
                            <RowDefinition Height="Auto"/>
                            <!-- Start -->
                            <RowDefinition Height="Auto"/>
                            <!-- End -->
                            <RowDefinition Height="Auto"/>
                            <!-- Rate -->
                            <RowDefinition Height="Auto"/>
                            <!-- Expected -->
                            <RowDefinition Height="Auto"/>
                            <!-- Price Change -->
                            <RowDefinition Height="Auto"/>
                            <!-- Future -->
                            <RowDefinition Height="Auto"/>
                            <!-- Description -->
                        </Grid.RowDefinitions>

                        <!-- Rate Type -->
                        <TextBlock Grid.Row="0" Text="Rate Type"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding RateTypes}"
                                  SelectedItem="{Binding SelectedRateType}"
                                  DisplayMemberPath="Description"
                                  Style="{StaticResource DetailComboBoxStyle}"/>

                        <!-- Start Date -->
                        <TextBlock Grid.Row="1" Text="Start Date"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <DatePicker Grid.Row="1" Grid.Column="1"
                                    SelectedDate="{Binding SelectedRate.StartRate}"
                                    Style="{StaticResource DetailDatePickerStyle}"/>

                        <!-- End Date -->
                        <TextBlock Grid.Row="2" Text="End Date"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <DatePicker Grid.Row="2" Grid.Column="1"
                                    SelectedDate="{Binding SelectedRate.EndRate}"
                                    Style="{StaticResource DetailDatePickerStyle}"/>

                        <!-- Rate -->
                        <TextBlock Grid.Row="3" Text="Rate"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding SelectedRate.RateValue, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource DetailTextBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStaffel}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Expected Price Change -->
                        <TextBlock Grid.Row="4" Text="Expected Price Change"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding SelectedRate.ExpectedPriceChange, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DetailTextBoxStyle}"/>

                        <!-- Price Change -->
                        <TextBlock Grid.Row="5" Text="Price Change"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox Grid.Row="5" Grid.Column="1"
                                 Text="{Binding SelectedRate.PriceChange}"
                                 IsReadOnly="True"
                                 Style="{StaticResource DetailTextBoxStyle}"/>

                        <!-- Future Price -->
                        <TextBlock Grid.Row="6" Text="Future Price"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <TextBlock Grid.Row="6" Grid.Column="1"
                                   Text="{Binding SelectedRate.FutureRate}"
                                   Style="{StaticResource DetailLabelStyle}"/>

                        <!-- Description -->
                        <TextBlock Grid.Row="7" Text="Description"
                                   Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox Grid.Row="7" Grid.Column="1"
                                 Text="{Binding SelectedRate.Description}"
                                 Style="{StaticResource DetailTextBoxStyle}"/>

                    </Grid>
                </GroupBox>

            </Grid>
        </Grid>
    </DockPanel>
</Window>