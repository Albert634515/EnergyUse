<Window x:Class="WpfUI.Views.Windows.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Export"
        Height="420"
        Width="650"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <BitmapImage x:Key="IconClose" UriSource="/Resources/crossed_24x24.png"/>
        <BitmapImage x:Key="IconExport" UriSource="/Resources/upload_24x24.png"/>
        <BitmapImage x:Key="IconOpenFile" UriSource="/Resources/open-file-icon.png"/>
    </Window.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding CloseCommand}">
                <Image Source="{StaticResource IconClose}" Width="20"/>
            </Button>
        </ToolBar>

        <!-- Statusbar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusMessage}" />
        </StatusBar>

        <!-- Content -->
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Address -->
            <TextBlock Text="Address" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding Addresses}"
                      SelectedItem="{Binding SelectedAddress}"
                      DisplayMemberPath="Description"
                      HorizontalAlignment="Left"
                      Width="250"/>

            <!-- Energy Type -->
            <TextBlock Text="Energy Type" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding EnergyTypes}"
                      SelectedItem="{Binding SelectedEnergyType}"
                      DisplayMemberPath="Name"
                      HorizontalAlignment="Left"
                      Width="250"/>

            <!-- Export file -->
            <TextBlock Text="Export file" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                <TextBox Text="{Binding ExportFileName}"
                         Width="250"
                         VerticalAlignment="Center"/>
                <Button Command="{Binding SelectExportFileCommand}"
                        Margin="10,0,0,0"
                        Width="32"
                        Height="32">
                    <Image Source="{StaticResource IconOpenFile}" Width="20"/>
                </Button>
            </StackPanel>

            <!-- Range -->
            <TextBlock Text="Range" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <RadioButton Content="All"
                             IsChecked="{Binding ExportAll}"
                             Margin="0,0,20,0"/>
                <RadioButton Content="Selected range"
                             IsChecked="{Binding ExportSelectedRange}"/>
            </StackPanel>

            <!-- Date From -->
            <TextBlock Text="From" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="4" Grid.Column="1"
                        SelectedDate="{Binding DateFrom}"
                        HorizontalAlignment="Left"
                        Width="150"/>

            <!-- Date Till -->
            <TextBlock Text="Till" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="5" Grid.Column="1"
                        SelectedDate="{Binding DateTill}"
                        HorizontalAlignment="Left"
                        Width="150"/>

            <!-- Export button -->
            <Button Grid.Row="6" Grid.Column="1"
                    Command="{Binding ExportCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0"
                    Width="120"
                    Height="32">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{StaticResource IconExport}" Width="20"/>
                    <TextBlock Text="Export" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>

        </Grid>
    </DockPanel>
</Window>